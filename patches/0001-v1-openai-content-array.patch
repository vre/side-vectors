+// OpenAI content may be a plain string or an array of typed parts
+// (agent clients like pi send [{"type":"text","text":...}, ...]).
+static std::string content_to_string(const json & c) {
+    if (c.is_string()) return c.get<std::string>();
+    if (c.is_array()) {
+        std::string out;
+        for (const auto & part : c) {
+            if (part.is_object() && part.value("type", "") == "text") {
+                out += part.value("text", "");
+            }
+        }
+        return out;
+    }
+    if (c.is_null()) return "";
+    return dump_json(c);
+}
